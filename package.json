{
  "name": "sql-template-typed",
  "version": "0.1.3",
  "description": "Parse SQL in TypeScript template literal types and infer the result shape from your schema — no codegen, no ORM.",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./pg": {
      "types": "./dist/adapters/pg.d.ts",
      "import": "./dist/adapters/pg.js"
    },
    "./mysql2": {
      "types": "./dist/adapters/mysql2.d.ts",
      "import": "./dist/adapters/mysql2.js"
    },
    "./postgres": {
      "types": "./dist/adapters/postgres.d.ts",
      "import": "./dist/adapters/postgres.js"
    },
    "./node-sqlite": {
      "types": "./dist/adapters/node-sqlite.d.ts",
      "import": "./dist/adapters/node-sqlite.js"
    },
    "./kysely": {
      "types": "./dist/adapters/kysely.d.ts",
      "import": "./dist/adapters/kysely.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "test:types": "tsc --noEmit -p tsconfig.json",
    "test:runtime": "vitest run",
    "test": "npm run test:types && npm run test:runtime",
    "prepublishOnly": "npm run test && npm run build"
  },
  "peerDependencies": {
    "kysely": ">=0.27.0",
    "mysql2": ">=3.0.0",
    "pg": ">=8.0.0",
    "postgres": ">=3.0.0",
    "typescript": ">=5.0.0"
  },
  "peerDependenciesMeta": {
    "kysely": {
      "optional": true
    },
    "mysql2": {
      "optional": true
    },
    "pg": {
      "optional": true
    },
    "postgres": {
      "optional": true
    }
  },
  "keywords": [
    "sql",
    "typescript",
    "template-literal-types",
    "type-inference",
    "type-safe",
    "compile-time",
    "no-codegen"
  ],
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "@types/pg": "^8.20.0",
    "kysely": "^0.29.4",
    "mysql2": "^3.23.0",
    "pg": "^8.22.0",
    "postgres": "^3.4.9",
    "typescript": "^5.6.0",
    "vitest": "^4.1.10"
  }
}
